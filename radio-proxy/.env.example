# Required: The 5-char host shortcode (from the BrowSDR share link)
WEBSDR_HOST_ID=abc12

# Required: Base URL of the WebSDR (for fetching TURN credentials)
WEBSDR_URL=https://your-browsdr.example.com

# VFO configuration
VFO_FREQ=100.0
VFO_MODE=wfm
# VFO_BANDWIDTH=        # Optional, uses mode default if not set
# VFO_VOLUME=100         # 0-100, default 100

# Server
# STREAM_PORT=3000       # HTTP server port
# MP3_BITRATE=128        # MP3 bitrate in kbps
